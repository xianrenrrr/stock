# Copy to `.env` for local installs. On Render, set these in the dashboard
# (NEVER commit a populated .env to git).

# === LLM providers ===
# Runtime LLM calls use Codex CLI by default. Run `codex login` locally.
# Claude CLI is optional fallback when installed/logged in.
ANTHROPIC_API_KEY=
CORE_LLM_BACKEND=codex_cli
SELF_REVIEW_BACKEND=codex_cli

# === API auth ===
# Bearer token required by every /stock/... endpoint. On Render, render.yaml asks
# Render to auto-generate a fresh one and store it in the dashboard.
STOCK_API_TOKEN=

# === Cost / language ===
DAILY_COST_CEILING_USD=10
RESEARCH_LANGUAGE=zh

# === Web search backends for autonomous discovery ===
# Set ONE of these. Tavily preferred (free 1000/mo).
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_API_KEY=
WEB_SEARCH_BACKEND=tavily

# === DB path ===
# Local default = data/stock.db. On Render the disk mounts to /var/data.
DB_PATH=data/stock.db

# === WeChat delivery (LOCAL Windows desktop only — not used on Render) ===
# Leave blank in cloud mode. The pyautogui path requires a Windows desktop with
# WeChat open; on Linux/Render the orchestrator skips delivery (DB-only).
WECHAT_PUSH_URL=
WECHAT_PUSH_TOKEN=
WECHAT_PUSH_FIELD_TO=to
WECHAT_PUSH_FIELD_TEXT=text

# === OpenClaw auto-trigger (LOCAL only) ===
# Set to false on Render -- there's no OpenClaw CLI in the cloud image.
OPENCLAW_AUTO_DELIVER=true
OPENCLAW_BIN=openclaw
OPENCLAW_AGENT=main

# === SEC EDGAR User-Agent (free, but they require identification) ===
EDGAR_USER_AGENT=stock-research 0.1 ops@example.com

# === Hybrid local + Render-free architecture ===
# STOCK_MODE: `local` (default) runs the full pipeline. `cloud_proxy` (set on
#   Render only) skips the scheduler -- Render is just a frontend.
STOCK_MODE=local
# RENDER_SYNC_URL: only set on the local laptop -- the public URL of your Render
#   service. Local pushes notes/tokens here every 5 min (keepalive) and pulls
#   boss replies. Leave blank if not deploying to Render.
RENDER_SYNC_URL=
